<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="gallery3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#B3D9FF;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#FFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FFE5E5;stop-opacity:1" />
    </linearGradient>
  </defs>

  <rect width="400" height="400" fill="url(#gallery3)"/>

  <!-- Church/Venue -->
  <rect x="120" y="100" width="160" height="200" fill="#FFF" stroke="#0066CC" stroke-width="3"/>
  <polygon points="200,60 240,100 160,100" fill="#FF69B4"/>

  <!-- Door -->
  <rect x="175" y="250" width="50" height="50" fill="#8B4513" stroke="#0066CC" stroke-width="2"/>
  <circle cx="220" cy="275" r="3" fill="#FFD700"/>

  <!-- Windows -->
  <rect x="140" y="130" width="35" height="35" fill="#B3D9FF" stroke="#0066CC" stroke-width="1"/>
  <line x1="157.5" y1="130" x2="157.5" y2="165" stroke="#0066CC" stroke-width="1"/>
  <line x1="140" y1="147.5" x2="175" y2="147.5" stroke="#0066CC" stroke-width="1"/>

  <rect x="225" y="130" width="35" height="35" fill="#B3D9FF" stroke="#0066CC" stroke-width="1"/>
  <line x1="242.5" y1="130" x2="242.5" y2="165" stroke="#0066CC" stroke-width="1"/>
  <line x1="225" y1="147.5" x2="260" y2="147.5" stroke="#0066CC" stroke-width="1"/>

  <!-- Flowers at entrance -->
  <circle cx="100" cy="280" r="10" fill="#FF69B4"/>
  <circle cx="90" cy="270" r="6" fill="#FFB6D9"/>
  <circle cx="110" cy="270" r="6" fill="#FFB6D9"/>

  <circle cx="300" cy="280" r="10" fill="#FF69B4"/>
  <circle cx="290" cy="270" r="6" fill="#FFB6D9"/>
  <circle cx="310" cy="270" r="6" fill="#FFB6D9"/>
</svg>