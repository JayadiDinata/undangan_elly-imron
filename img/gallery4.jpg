<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="gallery4" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFE5E5;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#FFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#B3D9FF;stop-opacity:1" />
    </linearGradient>
  </defs>

  <rect width="400" height="400" fill="url(#gallery4)"/>

  <!-- Celebration confetti -->
  <rect x="50" y="80" width="20" height="30" fill="#0066CC" transform="rotate(45 60 95)"/>
  <rect x="100" y="60" width="20" height="30" fill="#FF69B4" transform="rotate(-30 110 75)"/>
  <rect x="150" y="100" width="20" height="30" fill="#FFD700" transform="rotate(20 160 115)"/>
  <rect x="200" y="50" width="20" height="30" fill="#0066CC" transform="rotate(-45 210 65)"/>
  <rect x="250" y="90" width="20" height="30" fill="#FF69B4" transform="rotate(35 260 105)"/>
  <rect x="300" y="70" width="20" height="30" fill="#FFD700" transform="rotate(-20 310 85)"/>

  <!-- More confetti -->
  <circle cx="80" cy="150" r="8" fill="#0066CC"/>
  <circle cx="320" cy="200" r="8" fill="#FF69B4"/>
  <circle cx="120" cy="300" r="8" fill="#FFD700"/>
  <circle cx="280" cy="320" r="8" fill="#0066CC"/>

  <!-- Champagne glasses -->
  <path d="M 100 200 L 110 280 Q 105 290 100 290 Q 95 290 90 280 Z" fill="none" stroke="#FFD700" stroke-width="2"/>
  <polygon points="95,200 105,200 110,190 90,190" fill="none" stroke="#FFD700" stroke-width="2"/>
  <rect x="85" y="290" width="30" height="10" fill="#FFD700"/>

  <path d="M 300 200 L 310 280 Q 305 290 300 290 Q 295 290 290 280 Z" fill="none" stroke="#FFD700" stroke-width="2"/>
  <polygon points="295,200 305,200 310,190 290,190" fill="none" stroke="#FFD700" stroke-width="2"/>
  <rect x="285" y="290" width="30" height="10" fill="#FFD700"/>

  <!-- Sparkles -->
  <circle cx="200" cy="250" r="3" fill="#FFD700"/>
  <path d="M 200 240 L 200 260 M 190 250 L 210 250" stroke="#FFD700" stroke-width="1"/>
</svg>