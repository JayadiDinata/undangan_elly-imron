<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="groomGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E8F1FF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#B3D9FF;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="400" height="400" fill="url(#groomGradient)"/>

  <!-- Head -->
  <circle cx="200" cy="120" r="50" fill="#DEB887"/>

  <!-- Hair -->
  <ellipse cx="200" cy="110" rx="55" ry="45" fill="#333"/>

  <!-- Eyes -->
  <circle cx="185" cy="115" r="4" fill="#333"/>
  <circle cx="215" cy="115" r="4" fill="#333"/>

  <!-- Smile -->
  <path d="M 185 130 Q 200 140 215 130" stroke="#333" stroke-width="2" fill="none"/>

  <!-- Neck -->
  <rect x="190" y="165" width="20" height="15" fill="#DEB887"/>

  <!-- Shirt/Suit -->
  <path d="M 140 180 L 260 180 L 270 300 L 130 300 Z" fill="#1C1C1C"/>

  <!-- Tie -->
  <polygon points="200,185 195,210 205,210" fill="#0066CC"/>

  <!-- White Shirt Front -->
  <rect x="180" y="185" width="40" height="80" fill="#FFF"/>

  <!-- Jacket Lapels -->
  <polygon points="140,180 165,210 155,220 130,195" fill="#0A0A0A"/>
  <polygon points="260,180 235,210 245,220 270,195" fill="#0A0A0A"/>

  <!-- Buttons -->
  <circle cx="200" cy="220" r="3" fill="#CCC"/>
  <circle cx="200" cy="245" r="3" fill="#CCC"/>
  <circle cx="200" cy="270" r="3" fill="#CCC"/>

  <!-- Arms -->
  <ellipse cx="130" cy="220" rx="15" ry="50" fill="#1C1C1C"/>
  <ellipse cx="270" cy="220" rx="15" ry="50" fill="#1C1C1C"/>

  <!-- Hands -->
  <circle cx="125" cy="270" r="10" fill="#DEB887"/>
  <circle cx="275" cy="270" r="10" fill="#DEB887"/>
</svg>